<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hotel.controllers.LoginController"
            styleClass="root-pane">

    <center>
        <VBox alignment="CENTER" spacing="16" styleClass="card">
            <padding><Insets top="40" right="50" bottom="40" left="50"/></padding>

            <Label text="🏨 Hotel Reservation System" styleClass="title-label"/>
            <Label text="Please log in to continue" styleClass="subtitle-label"/>

            <!-- Login type selection -->
            <HBox alignment="CENTER" spacing="20">
                <RadioButton fx:id="guestRadio" text="Guest" selected="true" styleClass="radio-btn">
                    <toggleGroup><ToggleGroup fx:id="loginTypeGroup"/></toggleGroup>
                </RadioButton>
                <RadioButton fx:id="staffRadio" text="Staff" toggleGroup="$loginTypeGroup" styleClass="radio-btn"/>
            </HBox>

            <TextField fx:id="usernameField" promptText="Username" styleClass="input-field" maxWidth="300"/>
            <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field" maxWidth="300"/>

            <Label fx:id="statusLabel" text="" styleClass="status-label"/>

            <Button text="Login" onAction="#handleLogin" styleClass="primary-btn" maxWidth="300"/>
            <Button text="Register as Guest" onAction="#handleRegister" styleClass="secondary-btn" maxWidth="300"/>

            <Label text="Demo — Guest: Mario / 1234 | Staff: admin / admin123"
                   styleClass="hint-label"/>
        </VBox>
    </center>

</BorderPane>
